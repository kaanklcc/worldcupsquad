# AI consultant
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Authentication (operator-supplied, at least 32 random characters)
JWT_SECRET_KEY=

# x402. Kaan's named judge account has a free, explicitly labelled demo path.
# Submission default: every account starts locked, then may explicitly activate
# a labelled 30-minute, 0-USDC judge pass. Real browser-signed EIP-3009/x402
# remains a separate option when the facilitator values below are configured.
X402_DEMO_MODE=true
X402_ALLOW_SIMULATED_PURCHASES=true
HACKATHON_DEMO_MINUTES=30
X402_FACILITATOR_URL=
# x402 v2 / Injective EVM testnet (chain id 1439). Configure a real receiver
# before setting X402_DEMO_MODE=false.
X402_NETWORK=eip155:1439
X402_PAY_TO=
X402_ASSET=0x0C382e685bbeeFE5d3d9C29e29E341fEE8E84C5d
X402_FACILITATOR_TOKEN=
X402_RESOURCE_BASE_URL=http://localhost:8000

# Set false to spawn backend/app/mcp/server.py over MCP stdio.
MCP_SIMULATION=false

# Circle CCTP v2 testnet. WCAI never accepts a private key: the browser signs
# approve/burn/mint, Circle Iris supplies the attestation, and the API verifies
# both receipts before it credits the fantasy budget.
CIRCLE_API_KEY=
CCTP_SOURCE_DOMAIN=0
CCTP_DESTINATION_DOMAIN=29
CCTP_SOURCE_TOKEN=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
CCTP_DESTINATION_TOKEN=0x0C382e685bbeeFE5d3d9C29e29E341fEE8E84C5d
CCTP_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
CCTP_MESSAGE_TRANSMITTER=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275
CCTP_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
CCTP_INJECTIVE_RPC_URL=https://k8s.testnet.json-rpc.injective.network/

# Injective
INJECTIVE_MNEMONIC=
INJECTIVE_TESTNET=true

# Comma-separated frontend origins allowed to send credentialed browser
# requests. Add the exact HTTPS frontend URL before a public deployment.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001
