# AI consultant
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Authentication
JWT_SECRET_KEY=replace-with-a-long-random-secret

# x402. Keep true only for a local demo without a wallet/facilitator.
X402_DEMO_MODE=true
X402_ALLOW_SIMULATED_PURCHASES=false
X402_FACILITATOR_URL=
# x402 v2 / Injective EVM testnet (chain id 1439). Configure a real receiver
# before setting X402_DEMO_MODE=false.
X402_NETWORK=eip155:1439
X402_PAY_TO=0x0000000000000000000000000000000000000000
X402_ASSET=0x0000000000000000000000000000000000000000
X402_FACILITATOR_TOKEN=
X402_RESOURCE_BASE_URL=http://localhost:8000

# Set false to spawn backend/app/mcp/server.py over MCP stdio.
MCP_SIMULATION=false

# Circle CCTP. The current local flow is simulated until wallet signing is configured.
CIRCLE_API_KEY=
CCTP_SOURCE_DOMAIN=0
CCTP_DESTINATION_DOMAIN=3
CCTP_SOURCE_TOKEN=

# Injective
INJECTIVE_MNEMONIC=
INJECTIVE_TESTNET=true
