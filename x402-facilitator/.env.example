# Dedicated WCAI x402 facilitator. This is a separate testnet-only burner
# wallet, never a user's MetaMask key and never the wallet that receives USDC.
X402_FACILITATOR_PRIVATE_KEY=

# Bind to loopback in local development. Use a private internal network in a
# production deployment; do not expose this service directly to the internet.
X402_FACILITATOR_HOST=127.0.0.1
X402_FACILITATOR_PORT=4021

# Must match backend/.env exactly.
X402_NETWORK=eip155:1439
X402_ASSET=0x0C382e685bbeeFE5d3d9C29e29E341fEE8E84C5d
X402_PAY_TO=

# Optional private-network shared token. Required if binding beyond loopback.
X402_FACILITATOR_TOKEN=

# Injective EVM testnet RPC. The facilitator needs only test INJ for gas.
X402_FACILITATOR_RPC_URL=https://k8s.testnet.json-rpc.injective.network/

# Reject gas-griefing dust payments and accidental high-value requests.
X402_MIN_ATOMIC_AMOUNT=50000
X402_MAX_ATOMIC_AMOUNT=5000000
